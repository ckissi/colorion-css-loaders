---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CSS Loader Library — 99 pure-CSS loaders, free to copy',
  description = 'A library of 99 loading spinners built with pure CSS. Click any loader to copy its CSS — no JavaScript, no dependencies, MIT licensed.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Self-hosted fonts. Preload the above-the-fold weights (Inter 500 powers
         the hero h1 / LCP element; Inter 400 the body copy) so they arrive
         before paint and the headline doesn't swap late. @font-face lives in
         the inlined global.css. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-500-normal.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-400-normal.woff2" crossorigin />

    <!-- Privacy-friendly analytics by Plausible -->
    <script async is:inline src="https://plausible.elerion.com/js/pa-L8NIwV4t4Dr46R5dg2Req.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
